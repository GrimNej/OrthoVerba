{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "outDir": ".typecheck/app",
    "tsBuildInfoFile": ".typecheck/app.tsbuildinfo"
  },
  "include": [
    "src/main.tsx",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/application/**/*.ts",
    "src/domain/**/*.ts",
    "src/infrastructure/**/*.ts",
    "src/presentation/**/*.ts",
    "src/presentation/**/*.tsx"
  ],
  "exclude": [
    "src/workers/**",
    "src/infrastructure/audio/audio-telemetry-processor.ts",
    "src/infrastructure/audio/audio-worklet-globals.d.ts"
  ]
}
